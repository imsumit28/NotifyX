PORT=3000
NODE_ENV=development

# Redis — use Upstash URL (rediss://...) in production
REDIS_URL=redis://localhost:6379

# MongoDB Atlas — use mongodb+srv://... in production
MONGODB_URI=mongodb://localhost:27017/notifyx

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-in-production

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:8080

# Demo auth secret (used by POST /api/auth/token)
ADMIN_SECRET=notifyx-demo

# Logging
LOG_LEVEL=info
